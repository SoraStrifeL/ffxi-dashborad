# ── FFXI Dashboard – environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables have sane defaults for a default LandSandBoat Docker setup.

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: use the LSB service name (usually 'db')
# Bare-metal / remote: use the IP address or hostname
DB_HOST=db
DB_PORT=3306
DB_USER=xiadmin
DB_PASS=changeme
DB_NAME=xidb

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# Optional — restrict CORS to a specific origin (e.g. http://192.168.1.10:3001).
# Leave unset to block all cross-origin requests (recommended for LAN deployments).
# CORS_ORIGIN=http://your-dashboard-host:3001

# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_JWT_SECRET=

# ── LSB path roots ────────────────────────────────────────────────────────────
# Docker: leave these unset — the compose file mounts the paths at the defaults.
# Bare-metal Linux: set to wherever your LSB repo lives, e.g. /home/user/LandSandBoat
# Windows: use forward slashes or double-backslashes, e.g. D:/LSB or D:\\LSB
#
# LSB_SCRIPTS_DIR       scripts/           quests, missions, roe, key_item, title, effects…
# LSB_SETTINGS_DIR      settings/          main.lua, map.lua, login.lua
# LSB_LOG_DIR           log/               map-server.log, dashboard_positions.json
# LSB_SERVER_SCRIPTS_DIR  scripts/         Lua scripts exposed in the script editor tab
#
# Linux defaults (Docker volume mount targets):
# LSB_SCRIPTS_DIR=/ffxi-scripts
# LSB_SETTINGS_DIR=/ffxi-settings
# LSB_LOG_DIR=/ffxi-log
# LSB_SERVER_SCRIPTS_DIR=/ffxi-server-scripts
#
# Windows bare-metal example:
# LSB_SCRIPTS_DIR=D:/LSB/scripts
# LSB_SETTINGS_DIR=D:/LSB/settings
# LSB_LOG_DIR=D:/LSB/log
# LSB_SERVER_SCRIPTS_DIR=D:/LSB/scripts

# ── Docker networking ─────────────────────────────────────────────────────────
# Run `docker network ls` to find the name of your LSB network.
# Common values: landsandboat_default, xi_default, ffxi_xi_net
LSB_NETWORK=landsandboat_default
